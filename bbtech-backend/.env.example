# ============================================================
# BBTECH Backend — Variables de entorno
# Copiar como .env y completar con tus valores reales
# NUNCA subir .env a GitHub
# ============================================================

# Base de datos Neon PostgreSQL
# Obtener en: console.neon.tech → tu proyecto → Connection string
DATABASE_URL=postgresql://usuario:password@host.neon.tech/bbtech?sslmode=require

# JWT Secret — string largo y aleatorio
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_por_string_aleatorio_muy_largo_de_al_menos_64_caracteres

# Puerto del servidor (Render lo setea automáticamente)
PORT=3000

# Frontend URL (para CORS) — en producción tu dominio de Vercel
# En desarrollo: http://localhost:5500 o el puerto que uses
FRONTEND_URL=http://localhost:5500

# Entorno
NODE_ENV=development
